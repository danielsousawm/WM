rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true &&
             (request.auth.token.email == "danielsousawm@gmail.com" || 
              request.auth.token.email == "wellington.wmsaude@gmail.com");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidResponse(data) {
      return data.keys().hasAll([
        'municipality', 'technicalQuality', 'resolutivity', 
        'deadlineCompliance', 'communication', 'overallSatisfaction', 
        'average', 'date', 'sector'
      ]) &&
      data.municipality is string && data.municipality.size() <= 100 &&
      data.sector is string && data.sector.size() <= 50 &&
      data.technicalQuality is number && data.technicalQuality >= 0 && data.technicalQuality <= 10 &&
      data.resolutivity is number && data.resolutivity >= 0 && data.resolutivity <= 10 &&
      data.deadlineCompliance is number && data.deadlineCompliance >= 0 && data.deadlineCompliance <= 10 &&
      data.communication is number && data.communication >= 0 && data.communication <= 10 &&
      data.overallSatisfaction is number && data.overallSatisfaction >= 0 && data.overallSatisfaction <= 10 &&
      data.average is number && data.average >= 0 && data.average <= 10 &&
      data.date is string && data.date.size() <= 100 &&
      (!('suggestions' in data) || (data.suggestions is string && data.suggestions.size() <= 5000)) &&
      (!('clientName' in data) || (data.clientName is string && data.clientName.size() <= 500)) &&
      (!('clientPhone' in data) || (data.clientPhone is string && data.clientPhone.size() <= 50));
    }

    match /responses/{responseId} {
      allow create: if true; // Permite criação para qualquer um sem validação estrita temporária para debugar, ou use: if isValidResponse(request.resource.data);
      // Vamos manter a validação, mas garantir que o allow create não dependa de isSignedIn
      allow get, list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
